{
  // Use IntelliSense to learn about possible Node.js debug attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "${workspaceFolder}/workspace",
        "--extensionDevelopmentPath=${workspaceFolder}/application/vscode",
        "--disable-extensions"
      ],
      "sourceMaps": true,
      "smartStep": true,
      "outFiles": [
        "${workspaceFolder}/node_modules/eclipse-glsp/**/*.js",
        "${workspaceFolder}/application/**/*.js",
        "${workspaceFolder}/packages/**/*.js"
      ]
    },
    {
      "name": "(Attach) LSP Server",
      "type": "node",
      "request": "attach",
      "address": "localhost",
      "port": 6009,
      "restart": true,
      "protocol": "inspector",
      "timeout": 30000
      // Optional if you need source maps/path mapping:
      // "localRoot": "${workspaceFolder}",
      // "remoteRoot": "${workspaceFolder}",
      // "sourceMaps": true,
      // "outFiles": ["${workspaceFolder}/**/*.js"]
    }
  ],
  "compounds": [
    {
      "name": "Debug Extension",
      "configurations": ["Launch Extension", "(Attach) LSP Server"]
    }
  ]
}
