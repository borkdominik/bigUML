{
  "name": "@borkdominik-biguml/big-property-palette",
  "version": "0.6.4",
  "description": "UML-Property Palette",
  "homepage": "https://github.com/borkdominik/bigUML",
  "bugs": "https://github.com/borkdominik/bigUML/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/borkdominik/bigUML.git"
  },
  "license": "MIT",
  "author": {
    "name": "Business Informatics Group (TU Wien)"
  },
  "contributors": [
    {
      "name": "Business Informatics Group (TU Wien)",
      "email": "dominik.bork@tuwien.ac.at",
      "url": "https://me.big.tuwien.ac.at/"
    },
    {
      "name": "Haydar Metin",
      "email": "dev@haydar.metin.at",
      "url": "https://me.big.tuwien.ac.at/"
    }
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./build/env/common/index.d.ts",
      "default": "./build/env/common/index.js"
    },
    "./glsp-client": {
      "types": "./build/env/glsp-client/index.d.ts",
      "default": "./build/env/glsp-client/index.js"
    },
    "./glsp-server": {
      "types": "./build/env/glsp-server/index.d.ts",
      "default": "./build/env/glsp-server/index.js"
    },
    "./vscode": {
      "types": "./build/env/vscode/index.d.ts",
      "default": "./build/env/vscode/index.js"
    },
    "./jsx": {
      "types": "./build/env/jsx/index.d.ts",
      "default": "./build/env/jsx/index.js"
    },
    "./jsx/jsx-runtime": {
      "types": "./build/env/jsx/jsx-runtime.d.ts",
      "default": "./build/env/jsx/jsx-runtime.js"
    },
    "./generator": {
      "types": "./generator/index.ts",
      "default": "./generator/index.ts"
    },
    "./gen/glsp-server": {
      "types": "./build/gen/glsp-server/index.d.ts",
      "default": "./build/gen/glsp-server/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run clean && npm run compile && npm run bundle && npm run lint",
    "bundle": "tsx esbuild.ts",
    "clean": "rimraf build dist node_modules/.tmp",
    "compile": "tsc -b",
    "generate": "rimraf src/gen && npm run language:generate",
    "language:generate": "uml-language-tooling extension generate -d @borkdominik-biguml/uml-language/definition -c ./generator/index.ts",
    "lint": "eslint -c ./eslint.config.js",
    "lint:fix": "npm run lint -- --fix",
    "watch": "concurrently --kill-others 'npm run compile -- --watch' 'npm run bundle -- --watch'"
  },
  "dependencies": {
    "@borkdominik-biguml/big-components": "*",
    "@borkdominik-biguml/big-vscode": "*",
    "@borkdominik-biguml/uml-glsp-server": "*",
    "@borkdominik-biguml/uml-language-tooling": "*",
    "@borkdominik-biguml/uml-protocol": "*",
    "@eclipse-glsp/client": "*",
    "@eclipse-glsp/protocol": "*",
    "@eclipse-glsp/server": "*",
    "@eclipse-glsp/vscode-integration-webview": "*",
    "eta": "^3.5.0",
    "sortablejs": "^1.15.0",
    "vscode-messenger-common": "^0.4.5"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/sortablejs": "^1.15.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "peerDependencies": {
    "inversify": "^6.2.1",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  }
}
