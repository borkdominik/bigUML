{
  "name": "@borkdominik-biguml/big-vscode",
  "version": "0.6.4",
  "description": "BIG VSCode integration",
  "homepage": "https://github.com/borkdominik/bigUML",
  "bugs": "https://github.com/borkdominik/bigUML/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/borkdominik/bigUML.git"
  },
  "license": "MIT",
  "author": {
    "name": "Business Informatics Group (TU Wien)"
  },
  "contributors": [
    {
      "name": "Business Informatics Group (TU Wien)",
      "email": "dominik.bork@tuwien.ac.at",
      "url": "https://me.big.tuwien.ac.at/"
    },
    {
      "name": "Haydar Metin",
      "email": "dev@haydar.metin.at",
      "url": "https://me.big.tuwien.ac.at/"
    }
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./build/env/common/index.d.ts",
      "default": "./build/env/common/index.js"
    },
    "./glsp-client": {
      "types": "./build/env/glsp-client/index.d.ts",
      "default": "./build/env/glsp-client/index.js"
    },
    "./vscode": {
      "types": "./build/env/vscode/index.d.ts",
      "default": "./build/env/vscode/index.js"
    }
  },
  "scripts": {
    "build": "npm run clean && npm run compile && npm run lint",
    "clean": "rimraf build dist node_modules/.tmp",
    "compile": "tsc -b",
    "lint": "eslint -c ./eslint.config.js",
    "lint:ci": "npm run lint -o eslint.xml -f checkstyle",
    "lint:fix": "eslint --fix -c ./eslint.config.js",
    "watch": "concurrently --kill-others 'npm run watch:compile'",
    "watch:compile": "npm run compile -- --watch --preserveWatchOutput"
  },
  "dependencies": {
    "@borkdominik-biguml/big-common": "*",
    "@borkdominik-biguml/uml-glsp-server": "*",
    "@borkdominik-biguml/uml-model-server": "*",
    "@eclipse-glsp/vscode-integration": "*",
    "@eclipse-glsp/vscode-integration-webview": "*",
    "@types/vscode": "^1.63.0",
    "@vscode/codicons": "^0.0.25",
    "reflect-metadata": "^0.2.2",
    "vscode-messenger": "^0.4.5",
    "vscode-messenger-common": "^0.4.5"
  },
  "peerDependencies": {
    "inversify": "^6.2.1"
  }
}
