{
  "name": "@borkdominik-biguml/uml-glsp-jsx",
  "version": "0.6.4",
  "description": "JSX runtime for GLSP graphical model construction",
  "homepage": "https://github.com/borkdominik/bigUML",
  "bugs": "https://github.com/borkdominik/bigUML/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/borkdominik/bigUML.git"
  },
  "license": "MIT",
  "author": {
    "name": "Business Informatics Group (TU Wien)"
  },
  "contributors": [
    {
      "name": "Business Informatics Group (TU Wien)",
      "email": "dominik.bork@tuwien.ac.at",
      "url": "https://me.big.tuwien.ac.at/"
    },
    {
      "name": "Haydar Metin",
      "email": "dev@haydar.metin.at",
      "url": "https://me.big.tuwien.ac.at/"
    }
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    },
    "./jsx-runtime": {
      "types": "./build/jsx-runtime.d.ts",
      "default": "./build/jsx-runtime.js"
    }
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "npm run clean && npm run compile && npm run lint",
    "clean": "rimraf build dist node_modules/.tmp",
    "compile": "tsc -b",
    "lint": "eslint -c ./eslint.config.js",
    "lint:fix": "npm run lint -- --fix",
    "tsc": "tsc",
    "watch": "concurrently --kill-others 'npm run compile -- --watch'"
  },
  "dependencies": {
    "@eclipse-glsp/server": "*"
  }
}
