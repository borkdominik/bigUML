    export const <%~ entry.constName %> = representationTemplateTypeId('<%~ it.representation %>', DefaultTypes.EDGE, '<%~ entry.template %>', '<%~ entry.astName %>');
<% } else { %>
    export const <%~ entry.constName %> = representationTypeId('<%~ it.representation %>', DefaultTypes.EDGE, '<%~ entry.astName %>');
<% } %>
<% }) %>
}

<% /* ------------------------------------------------------------------ */ %>
<% /* Backwards-compatible merged namespace                              */ %>
<% /* ------------------------------------------------------------------ */ %>
export namespace <%~ it.diagramName %>DiagramModelTypes {
