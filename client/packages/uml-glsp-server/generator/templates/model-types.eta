<% } else { %>
    export const <%~ entry.constName %> = representationTypeId('<%~ it.representation %>', DefaultTypes.NODE, '<%~ entry.astName %>');
<% } %>
<% }) %>
}

<% /* ------------------------------------------------------------------ */ %>
