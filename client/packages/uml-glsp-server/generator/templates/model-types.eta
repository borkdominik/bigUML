<% it.nodes.forEach(function(entry) { %>
    export const <%~ entry.constName %> = <%~ it.diagramName %>DiagramNodeTypes.<%~ entry.constName %>;
<% }) %>

    // re-export edges
<% it.edges.forEach(function(entry) { %>
    export const <%~ entry.constName %> = <%~ it.diagramName %>DiagramEdgeTypes.<%~ entry.constName %>;
<% }) %>
}

<% /* ------------------------------------------------------------------ */ %>
<% /* AST type conversion                                                */ %>
<% /* ------------------------------------------------------------------ */ %>
export namespace <%~ it.diagramName %>AstTypes {
<% if (it.astAliases.length > 0) { %>
    const aliases: Record<string, string> = {
<% it.astAliases.forEach(function(alias) { %>
        [<%~ it.diagramName %>DiagramModelTypes.<%~ alias.constName %>]: '<%~ alias.astName %>',
<% }) %>
    };
<% } %>

    const typeMap: Record<string, string> = {
<% it.nodes.forEach(function(entry) { %>
        '<%~ entry.astName %>': <%~ it.diagramName %>DiagramModelTypes.<%~ entry.constName %>,
<% }) %>
<% it.edges.forEach(function(entry) { %>
        '<%~ entry.astName %>': <%~ it.diagramName %>DiagramModelTypes.<%~ entry.constName %>,
<% }) %>
    };

    export function convertToAst(elementId: string): string {
<% if (it.astAliases.length > 0) { %>
        if (aliases[elementId]) {
            return aliases[elementId];
        }
<% } %>
        return AstTypeUtils.stripPrefix(elementId);
    }

    export function convertToElementType(astType: string): string {
        const elementType = typeMap[astType];
        if (!elementType) {
            throw new Error(`[<%~ it.diagramName %>AstTypes] No element type found for AST type '${astType}'`);
