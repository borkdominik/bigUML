{
  "name": "@borkdominik-biguml/uml-glsp-server",
  "version": "0.6.4",
  "description": "UML-Hello World",
  "homepage": "https://github.com/borkdominik/bigUML",
  "bugs": "https://github.com/borkdominik/bigUML/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/borkdominik/bigUML.git"
  },
  "license": "MIT",
  "author": {
    "name": "Business Informatics Group (TU Wien)"
  },
  "contributors": [
    {
      "name": "Business Informatics Group (TU Wien)",
      "email": "dominik.bork@tuwien.ac.at",
      "url": "https://me.big.tuwien.ac.at/"
    },
    {
      "name": "Haydar Metin",
      "email": "dev@haydar.metin.at",
      "url": "https://me.big.tuwien.ac.at/"
    }
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./build/env/common/index.d.ts",
      "default": "./build/env/common/index.js"
    },
    "./vscode": {
      "types": "./build/env/vscode/index.d.ts",
      "default": "./build/env/vscode/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run clean && npm run compile && npm run lint",
    "clean": "rimraf build dist node_modules/.tmp",
    "compile": "tsc -b",
    "generate": "npm run language:generate",
    "language:generate": "uml-language-tooling extension generate -d @borkdominik-biguml/uml-language/definition -c ./generator/index.ts",
    "lint": "eslint -c ./eslint.config.js",
    "lint:fix": "npm run lint -- --fix",
    "tsc": "tsc",
    "watch": "concurrently --kill-others 'npm run compile -- --watch'"
  },
  "dependencies": {
    "@borkdominik-biguml/model-server": "*",
    "@borkdominik-biguml/uml-language-tooling": "*",
    "@eclipse-glsp/client": "*",
    "@eclipse-glsp/layout-elk": "*",
    "@eclipse-glsp/protocol": "*",
    "@eclipse-glsp/server": "*",
    "fast-json-patch": "^3.1.1"
  },
  "devDependencies": {},
  "peerDependencies": {
    "inversify": "^6.2.1"
  }
}
