DiagramType  : ActivityDiagram | ClassDiagram | CommunicationDiagram | DeploymentDiagram | InformationFlowDiagram | PackageDiagram | StateMachineDiagram | UseCaseDiagram ;
UseCaseDiagramElements  : UseCaseDiagramNodes | UseCaseDiagramEdges ;
UseCaseDiagramNodes  : UseCase | Actor | Subject ;
UseCaseDiagramEdges  : Include | Extend | Association | Generalization ;
Visibility  returns string : "PUBLIC" | "PRIVATE" | "PROTECTED" | "PACKAGE" ;
AggregationType  returns string : "NONE" | "SHARED" | "COMPOSITE" ;
DataTypeReference  : DataType | Enumeration | Class | Interface | PrimitiveType ;
Concurrency  returns string : "SEQUENTIAL" | "GUARDED" | "CONCURRENT" ;
ParameterDirection  returns string : "IN" | "OUT" | "INOUT" | "RETURN" ;
EffectType  returns string : "CREATE" | "READ" | "UPDATE" | "DELETE" ;
StateMachineDiagramElements  : StateMachineDiagramNodes | StateMachineDiagramEdges ;
StateMachineDiagramNodes  : StateMachine | Region | State | FinalState | InitialState | Choice | Join | Fork | DeepHistory | ShallowHistory ;
StateMachineDiagramEdges  : Transition ;
TransitionKind  returns string : "INTERNAL" | "EXTERNAL" | "LOCAL" ;
